---
// Site footer — scrolling marquee, link columns, brand block with
// socials + app badges, secure-payment strip, and the legal bar.
import {
  SITE,
  FOOTER_MARQUEE,
  FOOTER_COLUMNS,
  SOCIALS,
  PAYMENTS,
  LEGAL_LINKS,
  COPYRIGHT,
} from '~/config/site';

// Social icon paths (single <path>) keyed by icon name from config.
const SOCIAL_ICONS: Record<string, string> = {
  x: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  youtube:
    'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  linkedin:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  tiktok:
    'M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.73a8.18 8.18 0 004.78 1.52V6.79a4.85 4.85 0 01-1.01-.1z',
};
---

<footer class="footer" aria-label="Site footer">
  <!-- Scrolling text marquee -->
  <div class="footer-marquee-bar" aria-hidden="true">
    <div class="footer-marquee-track">
      {[...FOOTER_MARQUEE, ...FOOTER_MARQUEE].map((m) => (
        <span class="fm-item">
          <span class={`fm-text${m.outlined ? ' outlined' : ''}`}>{m.text}</span>
          <span class="fm-star">&#10022;</span>
        </span>
      ))}
    </div>
  </div>

  <!-- Main footer -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-top">
        <!-- Brand column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo">{SITE.name}<span class="dot">{SITE.brandDot}</span></a>
          <p class="footer-desc">{SITE.description}</p>
          <div class="footer-socials">
            {SOCIALS.map((s) => (
              <a href={s.href} class="social-btn" aria-label={s.label}>
                {s.icon === 'instagram' ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="2" y="2" width="20" height="20" rx="5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                  </svg>
                ) : (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d={SOCIAL_ICONS[s.icon]} />
                  </svg>
                )}
              </a>
            ))}
          </div>
          <div class="footer-app-row">
            <a href="#" class="footer-app-badge" aria-label="Download on App Store">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="rgba(255,255,255,0.5)">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
              </svg>
              <div class="footer-app-badge-text">
                <span class="footer-app-badge-sub">Download on the</span>
                <span class="footer-app-badge-name">App Store</span>
              </div>
            </a>
            <a href="#" class="footer-app-badge" aria-label="Get on Google Play">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="rgba(255,255,255,0.5)">
                <path d="M3.18 23.76c.3.17.64.24.99.2l12.29-12.29L13 8.22 3.18 23.76zm17.89-11.1L18.44 11l-2.8 2.8 2.8 2.8 2.64-1.52c.75-.43.75-1.59-.01-2.42zM.01 1.05C-.04 1.24-.01 1.45.07 1.65L12.55 14.1l3.43-3.43L1.99.33C1.38-.03.37.1.01 1.05zm3.17 1.19L13 17.78l3.46-3.46-12.28-12.28-.6.2z" />
              </svg>
              <div class="footer-app-badge-text">
                <span class="footer-app-badge-sub">Get it on</span>
                <span class="footer-app-badge-name">Google Play</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Link columns -->
        {FOOTER_COLUMNS.map((col) => (
          <div class="footer-col">
            <h5>{col.title}</h5>
            <ul class="footer-links">
              {col.links.map((link) => (
                <li>
                  <a href={link.href} style={link.accent ? 'color:var(--gold);' : undefined}>{link.label}</a>
                  {link.badge && <span class="footer-link-badge">{link.badge}</span>}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Payment methods -->
      <div class="footer-payment-strip">
        <span class="footer-payment-label">Secure payments</span>
        <div class="footer-payment-icons">
          {PAYMENTS.map((p) => <span class="pay-chip">{p}</span>)}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="container">
    <div class="footer-bottom">
      <p class="footer-legal">{COPYRIGHT}</p>
      <div class="footer-legal-links">
        {LEGAL_LINKS.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    </div>
  </div>
</footer>
