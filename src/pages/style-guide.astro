---
// Style guide — a living reference of the Aurelis design system.
import BaseLayout from '~/layouts/BaseLayout.astro';

const colors = [
  { name: 'Obsidian', token: '--obsidian', hex: '#07080C', dark: true },
  { name: 'Graphite', token: '--graphite', hex: '#111318', dark: true },
  { name: 'Carbon', token: '--carbon', hex: '#171717', dark: true },
  { name: 'Gold', token: '--gold', hex: '#C9A86A', dark: false },
  { name: 'Gold Hover', token: '--gold-hover', hex: '#B8966A', dark: false },
  { name: 'Taupe', token: '--taupe', hex: '#8B8175', dark: true },
  { name: 'Platinum', token: '--platinum', hex: '#E7E2D9', dark: false },
  { name: 'Ivory', token: '--ivory', hex: '#F8F6F1', dark: false },
  { name: 'White', token: '--white', hex: '#FFFFFF', dark: false },
];

const typeScale = [
  { tag: 'H1', cls: 'sg-h1', sample: 'Engineered Excellence', meta: 'Sora · 600 · clamp 40–68px' },
  { tag: 'H2', cls: 'sg-h2', sample: 'The Curated Collection', meta: 'Sora · 600 · 40px' },
  { tag: 'H3', cls: 'sg-h3', sample: 'Crafted Without Compromise', meta: 'Sora · 600 · 28px' },
  { tag: 'H4', cls: 'sg-h4', sample: 'Designed for the Discerning', meta: 'Sora · 600 · 20px' },
  { tag: 'Body', cls: 'sg-body', sample: 'Every product in the Aurelis collection is selected for its design integrity, performance, and longevity.', meta: 'Inter · 400 · 16px' },
  { tag: 'Small', cls: 'sg-small', sample: 'Complimentary shipping on orders over $500.', meta: 'Inter · 400 · 13px' },
];
---

<BaseLayout title="Style Guide" description="A living reference of the Aurelis design system — colors, typography, buttons, and form elements.">
  <section class="doc-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <span class="current">Style Guide</span>
      </nav>
      <span class="eyebrow">
        <span class="eyebrow-line"></span>
        <span class="eyebrow-text">Design system</span>
      </span>
      <h1 class="doc-title">Style Guide</h1>
      <p class="doc-sub">The building blocks of the Aurelis brand — color, type, and components, all drawn from the same design tokens the storefront uses.</p>
    </div>
  </section>

  <section class="doc-body">
    <div class="container">

      <!-- Colors -->
      <div class="sg-section">
        <div class="sg-section-head">
          <span class="sg-num">01</span>
          <h2 class="sg-section-title">Color</h2>
        </div>
        <div class="sg-swatches">
          {colors.map((c) => (
            <div class="sg-swatch">
              <div class="sg-chip" style={`background:${c.hex};${c.hex === '#FFFFFF' ? 'border:1px solid var(--line);' : ''}`}>
                <span class="sg-chip-hex" style={`color:${c.dark ? 'rgba(255,255,255,0.85)' : 'var(--carbon)'}`}>{c.hex}</span>
              </div>
              <div class="sg-chip-meta">
                <span class="sg-chip-name">{c.name}</span>
                <code class="sg-chip-token">var({c.token})</code>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Typography -->
      <div class="sg-section">
        <div class="sg-section-head">
          <span class="sg-num">02</span>
          <h2 class="sg-section-title">Typography</h2>
        </div>
        <div class="sg-type-list">
          {typeScale.map((t) => (
            <div class="sg-type-row">
              <span class="sg-type-tag">{t.tag}</span>
              <div class="sg-type-sample">
                <p class={t.cls}>{t.sample}</p>
                <span class="sg-type-meta">{t.meta}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Buttons -->
      <div class="sg-section">
        <div class="sg-section-head">
          <span class="sg-num">03</span>
          <h2 class="sg-section-title">Buttons</h2>
        </div>
        <div class="sg-buttons">
          <a href="#" class="btn-dark">Dark Button</a>
          <a href="#" class="btn-gold">Gold Button</a>
          <a href="#" class="btn-dark-outline">Outline Button</a>
          <a href="#" class="view-all">View All Link
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <div class="sg-buttons sg-buttons-dark">
          <a href="#" class="btn-gold">Gold Button</a>
          <a href="#" class="btn-ghost-white">Ghost Button</a>
        </div>
      </div>

      <!-- Labels & badges -->
      <div class="sg-section">
        <div class="sg-section-head">
          <span class="sg-num">04</span>
          <h2 class="sg-section-title">Labels &amp; Badges</h2>
        </div>
        <div class="sg-badges">
          <span class="eyebrow"><span class="eyebrow-line"></span><span class="eyebrow-text">Eyebrow Label</span></span>
          <span class="sg-badge sg-badge-gold">New</span>
          <span class="sg-badge sg-badge-soft">Bestseller</span>
          <span class="sg-badge sg-badge-disc">-20%</span>
        </div>
      </div>

      <!-- Form elements -->
      <div class="sg-section">
        <div class="sg-section-head">
          <span class="sg-num">05</span>
          <h2 class="sg-section-title">Form Elements</h2>
        </div>
        <form class="sg-form" onsubmit="return false">
          <div class="sg-field">
            <label class="sg-label" for="sg-name">Full name</label>
            <input class="sg-input" id="sg-name" type="text" placeholder="Jane Appleseed" />
          </div>
          <div class="sg-field">
            <label class="sg-label" for="sg-email">Email address</label>
            <input class="sg-input" id="sg-email" type="email" placeholder="jane@example.com" />
          </div>
          <div class="sg-field sg-field-full">
            <label class="sg-label" for="sg-msg">Message</label>
            <textarea class="sg-input" id="sg-msg" rows="4" placeholder="How can we help?"></textarea>
          </div>
          <div class="sg-field sg-field-full sg-field-inline">
            <input type="checkbox" id="sg-check" class="sg-check" />
            <label for="sg-check" class="sg-check-label">Keep me updated with new arrivals and offers.</label>
          </div>
          <div class="sg-field-full">
            <button type="submit" class="btn-dark">Submit</button>
          </div>
        </form>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .doc-hero {
    background: var(--obsidian);
    color: var(--white);
    padding: 40px 0 80px;
    position: relative;
    overflow: hidden;
  }
  .doc-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at 80% -10%, rgba(201,168,106,0.15) 0%, transparent 55%);
  }
  .doc-hero .container { position: relative; z-index: 1; }
  .breadcrumb { display: flex; align-items: center; gap: 10px; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; font-weight: 600; margin: 14px 0 38px; }
  .breadcrumb a { color: rgba(255,255,255,0.5); transition: color var(--t-fast) ease; }
  .breadcrumb a:hover { color: var(--white); }
  .breadcrumb .crumb-sep { color: var(--gold-dim); }
  .breadcrumb .current { color: rgba(255,255,255,0.85); }
  .doc-hero .eyebrow { margin-bottom: 18px; }
  .doc-title {
    font-family: var(--font-heading);
    font-size: clamp(40px, 5.5vw, 68px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    margin-bottom: 18px;
  }
  .doc-sub { font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.7; max-width: 600px; }

  /* Body */
  .doc-body { padding: 80px 0 110px; }

  .sg-section { padding: 48px 0; border-top: 1px solid var(--line); }
  .sg-section:first-child { border-top: none; padding-top: 0; }
  .sg-section-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 36px; }
  .sg-num {
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.1em;
  }
  .sg-section-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 600;
    color: var(--carbon);
    letter-spacing: -0.02em;
  }

  /* Colors */
  .sg-swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 18px;
  }
  .sg-chip {
    height: 120px;
    border-radius: var(--r-lg);
    display: flex;
    align-items: flex-end;
    padding: 14px;
  }
  .sg-chip-hex { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; }
  .sg-chip-meta { display: flex; flex-direction: column; gap: 3px; margin-top: 12px; }
  .sg-chip-name { font-size: 14px; font-weight: 600; color: var(--carbon); }
  .sg-chip-token { font-size: 11.5px; color: var(--taupe); font-family: ui-monospace, monospace; }

  /* Typography */
  .sg-type-list { display: flex; flex-direction: column; }
  .sg-type-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 28px;
    align-items: baseline;
    padding: 24px 0;
    border-bottom: 1px solid var(--line);
  }
  .sg-type-row:last-child { border-bottom: none; }
  .sg-type-tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    padding-top: 6px;
  }
  .sg-type-sample { display: flex; flex-direction: column; gap: 8px; }
  .sg-type-meta { font-size: 12px; color: var(--taupe); font-family: ui-monospace, monospace; }
  .sg-h1 { font-family: var(--font-heading); font-size: clamp(36px, 5vw, 60px); font-weight: 600; line-height: 1.05; letter-spacing: -0.03em; color: var(--carbon); }
  .sg-h2 { font-family: var(--font-heading); font-size: 40px; font-weight: 600; line-height: 1.1; letter-spacing: -0.025em; color: var(--carbon); }
  .sg-h3 { font-family: var(--font-heading); font-size: 28px; font-weight: 600; line-height: 1.2; letter-spacing: -0.02em; color: var(--carbon); }
  .sg-h4 { font-family: var(--font-heading); font-size: 20px; font-weight: 600; line-height: 1.3; color: var(--carbon); }
  .sg-body { font-size: 16px; line-height: 1.7; color: #3a3632; max-width: 640px; }
  .sg-small { font-size: 13px; color: var(--taupe); }

  /* Buttons */
  .sg-buttons { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .sg-buttons + .sg-buttons { margin-top: 18px; }
  .sg-buttons-dark { background: var(--obsidian); padding: 28px; border-radius: var(--r-lg); }

  /* Badges */
  .sg-badges { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .sg-badges .eyebrow { margin-bottom: 0; }
  .sg-badge {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: var(--r-pill);
  }
  .sg-badge-gold { background: var(--gold); color: var(--obsidian); }
  .sg-badge-soft { background: var(--soft-bg); color: var(--carbon); border: 1px solid var(--line); }
  .sg-badge-disc { background: var(--obsidian); color: var(--white); }

  /* Form */
  .sg-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    max-width: 680px;
  }
  .sg-field { display: flex; flex-direction: column; gap: 8px; }
  .sg-field-full { grid-column: 1 / -1; }
  .sg-field-inline { flex-direction: row; align-items: center; gap: 10px; }
  .sg-label { font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--carbon); }
  .sg-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--carbon);
    background: var(--white);
    border: 1px solid var(--line-strong);
    border-radius: var(--r-md);
    padding: 13px 16px;
    transition: border-color var(--t-base) ease, box-shadow var(--t-base) ease;
    resize: vertical;
  }
  .sg-input::placeholder { color: var(--taupe); }
  .sg-input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 0 3px var(--gold-glow); }
  .sg-check { width: 18px; height: 18px; accent-color: var(--gold); flex-shrink: 0; }
  .sg-check-label { font-size: 14px; color: var(--taupe); }

  @media (max-width: 640px) {
    .sg-type-row { grid-template-columns: 1fr; gap: 10px; }
    .sg-form { grid-template-columns: 1fr; }
  }
</style>
