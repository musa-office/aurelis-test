---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Newsletter from '~/components/home/Newsletter.astro';
import { getBlogArticles } from '~/lib/shopify';
import type { BlogArticle } from '~/lib/shopify/types';
import '~/styles/pages/blog.css';

// The Aurelis journal lives on Shopify's default "news" blog.
const BLOG_HANDLE = 'news';

let articles: BlogArticle[] = [];

try {
  articles = await getBlogArticles(BLOG_HANDLE, 12);
} catch {
  // fall through to static
}

function fmtDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function estimateRead(html: string): string {
  const words = html.replace(/<[^>]*>/g, ' ').split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 250))} min read`;
}

function initials(name: string): string {
  return name.split(' ').map((p) => p[0] ?? '').join('').slice(0, 2).toUpperCase();
}

const STATIC = [
  { img: '/images/mpan0mun-blog-1.jpg', cat: 'Buying Guide', read: '8 min read', date: 'May 2025', title: 'The Best Premium Laptops of 2025 — Ranked by Our Editors', excerpt: "We tested 14 premium laptops over six weeks. Here's what's actually worth your investment this year.", authorName: 'James Reid', href: '#' },
  { img: '/images/mpan0muq-blog-2.jpg', cat: 'Review',       read: '6 min read', date: 'Apr 2025', title: 'SoundCraft Elite ANC Review — The Headphones That Changed Everything', excerpt: "Six months of daily use, studio sessions, and long-haul flights. Here's our complete verdict.", authorName: 'Sara Lin', href: '#' },
  { img: '/images/mpan0mus-blog-3.jpg', cat: 'Comparison',   read: '10 min read', date: 'Apr 2025', title: 'AuraPhone Pro Max vs. Competition — Who Wins in 2025?', excerpt: 'A rigorous head-to-head covering camera, performance, battery, and build quality across five flagship phones.', authorName: 'Marcus K.', href: '#' },
  { img: '/images/mpan0mun-blog-1.jpg', cat: 'Guide',        read: '7 min read', date: 'Mar 2025', title: 'How to Choose the Perfect Smartwatch in 2025', excerpt: "From fitness tracking to luxury complications — a complete buyer's guide for every wrist.", authorName: 'Aurelis Editors', href: '#' },
  { img: '/images/mpan0muq-blog-2.jpg', cat: 'Inside Aurelis', read: '5 min read', date: 'Mar 2025', title: 'Inside Our Curation Process: How We Select Every Product', excerpt: 'Less than 4% of products we evaluate make it into the collection. Here\'s what the process looks like.', authorName: 'Elias Mørk', href: '#' },
  { img: '/images/mpan0mus-blog-3.jpg', cat: 'Audio',        read: '9 min read', date: 'Feb 2025', title: 'The Ultimate Guide to High-Fidelity Home Audio', excerpt: 'Speakers, DACs, amplifiers, cables — everything you need to build a reference home audio system.', authorName: 'Marcus K.', href: '#' },
];

const posts = articles.length > 0
  ? articles.map((a) => ({
      img: a.image?.url ?? '',
      cat: a.tags[0] ?? 'Article',
      read: a.contentHtml ? estimateRead(a.contentHtml) : '',
      date: fmtDate(a.publishedAt),
      title: a.title,
      excerpt: a.excerpt ?? '',
      authorName: a.authorName ?? 'Aurelis Editors',
      authorInitials: initials(a.authorName ?? 'OE'),
      href: `/blog/${a.handle}`,
    }))
  : STATIC.map((p) => ({ ...p, authorInitials: initials(p.authorName) }));

const [featured, ...rest] = posts;
---

<BaseLayout title="The Edit — Expert Guides & Reviews" description="In-depth reviews, buying guides, and stories from the Aurelis curation team.">
  <section class="blog-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="crumb-sep">/</span>
        <span class="current">The Edit</span>
      </nav>
      <div class="bh-eyebrow">
        <span class="bh-eyebrow-dot"></span>
        <span>Expert Guides &amp; Reviews</span>
      </div>
      <h1 class="bh-title">The <span class="t-gold">Edit</span></h1>
      <p class="bh-sub">In-depth reviews, buying guides, and stories from the people who curate Aurelis — written to help you choose well.</p>
    </div>
  </section>

  <section class="blog-listing">
    <div class="container">

      {featured && (
        <a href={featured.href} class="blog-featured">
          <div class="blog-feat-media">
            {featured.img
              ? <img src={featured.img} alt={featured.title} loading="eager" />
              : <div class="blog-feat-placeholder"></div>}
            <div class="blog-feat-overlay"></div>
            <span class="blog-feat-badge">{featured.cat}</span>
            {featured.read && <span class="blog-feat-read">{featured.read}</span>}
          </div>
          <div class="blog-feat-body">
            <div class="blog-feat-eyebrow">
              <span class="blog-feat-eyebrow-line"></span>
              <span class="blog-feat-date">{featured.date}</span>
            </div>
            <h2 class="blog-feat-title">{featured.title}</h2>
            {featured.excerpt && <p class="blog-feat-excerpt">{featured.excerpt}</p>}
            <div class="blog-feat-footer">
              <div class="blog-feat-author">
                <div class="blog-feat-av">{featured.authorInitials}</div>
                <span class="blog-feat-author-name">{featured.authorName}</span>
              </div>
              <span class="blog-feat-cta">
                Read Article
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </span>
            </div>
          </div>
        </a>
      )}

      {rest.length > 0 && (
        <>
          <div class="blog-grid-head">
            <h2 class="blog-grid-title">More from The Edit</h2>
            <span class="blog-count">{posts.length} articles</span>
          </div>
          <div class="blog-cards-grid">
            {rest.map((p) => (
              <article class="bl-card">
                <a href={p.href} class="bl-card-media">
                  {p.img
                    ? <img src={p.img} alt={p.title} loading="lazy" />
                    : <div class="bl-card-placeholder"></div>}
                  <div class="bl-card-overlay"></div>
                  <span class="bl-card-cat">{p.cat}</span>
                  {p.read && <span class="bl-card-read">{p.read}</span>}
                </a>
                <div class="bl-card-body">
                  <div class="bl-card-eyebrow">
                    <span class="bl-card-line"></span>
                    <span class="bl-card-date">{p.date}</span>
                  </div>
                  <h3 class="bl-card-title"><a href={p.href}>{p.title}</a></h3>
                  {p.excerpt && <p class="bl-card-excerpt">{p.excerpt}</p>}
                  <div class="bl-card-foot">
                    <div class="bl-card-author">
                      <div class="bl-card-av">{p.authorInitials}</div>
                      <span class="bl-card-author-name">{p.authorName}</span>
                    </div>
                    <a href={p.href} class="bl-card-link">
                      Read
                      <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </>
      )}

    </div>
  </section>

  <Newsletter />
</BaseLayout>
