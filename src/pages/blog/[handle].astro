---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Newsletter from '~/components/home/Newsletter.astro';
import { getArticle, getBlogArticles } from '~/lib/shopify';
import type { BlogArticle } from '~/lib/shopify/types';
import '~/styles/pages/blog.css';

// The Aurelis journal lives on Shopify's default "news" blog.
const BLOG_HANDLE = 'news';
const { handle } = Astro.params;

let article: BlogArticle | null = null;
let related: BlogArticle[] = [];
let loadFailed = false;

try {
  article = await getArticle(BLOG_HANDLE, handle!);
} catch {
  loadFailed = true;
}

if (article) {
  try {
    const all = await getBlogArticles(BLOG_HANDLE, 4);
    related = all.filter((a) => a.handle !== handle);
  } catch {
    // non-fatal
  }
}

if (loadFailed) {
  Astro.response.status = 503;
} else if (!article) {
  Astro.response.status = 404;
}

function fmtDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function fmtDateShort(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function estimateRead(html: string): string {
  const words = html.replace(/<[^>]*>/g, ' ').split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 250))} min read`;
}

function initials(name: string): string {
  return name.split(' ').map((p) => p[0] ?? '').join('').slice(0, 2).toUpperCase();
}

const readTime = article?.contentHtml ? estimateRead(article.contentHtml) : '';
const authorName = article?.authorName ?? 'Aurelis Editors';
const authorInitials = initials(authorName);
const sub = article?.excerpt ?? article?.title ?? '';
---

<BaseLayout
  title={article?.title}
  description={sub.slice(0, 160)}
  image={article?.image?.url}
>
  {!article ? (
    <section class="container" style="padding:120px 0;text-align:center;">
      <h1 style="font-family:var(--font-heading);font-size:36px;font-weight:600;color:var(--carbon);margin-bottom:12px;">
        {loadFailed ? 'Something went wrong' : 'Article not found'}
      </h1>
      <p style="color:var(--taupe);margin-bottom:28px;">
        {loadFailed
          ? 'We could not load this article right now. Please try again shortly.'
          : "This article doesn't exist or is no longer available."}
      </p>
      <a href="/blog" class="btn-dark">Back to The Edit</a>
    </section>
  ) : (
    <>
      <section class="blog-hero">
        <div class="container">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span class="crumb-sep">/</span>
            <a href="/blog">The Edit</a>
            <span class="crumb-sep">/</span>
            <span class="current">{article.title}</span>
          </nav>
          <div class="ah-cat">
            {article.tags[0] && <span class="ah-cat-badge">{article.tags[0]}</span>}
            {readTime && <span class="ah-cat-read">{readTime}</span>}
          </div>
          <h1 class="ah-title">{article.title}</h1>
          <div class="ah-meta">
            <div class="ah-author">
              <div class="ah-author-av">{authorInitials}</div>
              <div>
                <div class="ah-author-name">{authorName}</div>
                <div class="ah-author-date">{fmtDate(article.publishedAt)}</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <article class="article-main">
        <div class="container">
          <div class="article-layout">

            <div class="article-body">
              {article.image && (
                <div class="article-hero-img">
                  <img
                    src={article.image.url}
                    alt={article.image.altText ?? article.title}
                    loading="eager"
                    width={article.image.width ?? undefined}
                    height={article.image.height ?? undefined}
                  />
                </div>
              )}

              {article.contentHtml
                ? <div class="article-prose" set:html={article.contentHtml}></div>
                : article.excerpt && <p class="article-prose">{article.excerpt}</p>
              }

              {article.tags.length > 0 && (
                <div class="article-tags">
                  <span class="article-tags-label">Topics</span>
                  {article.tags.map((tag) => (
                    <span class="article-tag">{tag}</span>
                  ))}
                </div>
              )}

              <div class="article-share">
                <span class="article-share-label">Share</span>
                <a href="#" class="article-share-btn" aria-label="Share on X / Twitter">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href="#" class="article-share-btn" aria-label="Share on LinkedIn">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <a href="#" class="article-share-btn" aria-label="Copy link">
                  <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="16" height="16" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                </a>
              </div>

              {related.length > 0 && (
                <section class="section-related-articles">
                  <div class="sec-eyebrow">
                    <span class="sec-eyebrow-line"></span>
                    <span class="sec-eyebrow-text">Continue Reading</span>
                  </div>
                  <h2 class="sec-title">More from <span class="t-gold">The Edit</span></h2>
                  <div class="blog-cards-grid">
                    {related.slice(0, 3).map((a) => (
                      <article class="bl-card">
                        <a href={`/blog/${a.handle}`} class="bl-card-media">
                          {a.image?.url
                            ? <img src={a.image.url} alt={a.image.altText ?? a.title} loading="lazy" />
                            : <div class="bl-card-placeholder"></div>}
                          <div class="bl-card-overlay"></div>
                          {a.tags[0] && <span class="bl-card-cat">{a.tags[0]}</span>}
                        </a>
                        <div class="bl-card-body">
                          <div class="bl-card-eyebrow">
                            <span class="bl-card-line"></span>
                            <span class="bl-card-date">{fmtDateShort(a.publishedAt)}</span>
                          </div>
                          <h3 class="bl-card-title">
                            <a href={`/blog/${a.handle}`}>{a.title}</a>
                          </h3>
                          {a.excerpt && <p class="bl-card-excerpt">{a.excerpt}</p>}
                          <div class="bl-card-foot">
                            <div class="bl-card-author">
                              <div class="bl-card-av">{initials(a.authorName ?? 'OE')}</div>
                              <span class="bl-card-author-name">{a.authorName ?? 'Aurelis Editors'}</span>
                            </div>
                            <a href={`/blog/${a.handle}`} class="bl-card-link">
                              Read
                              <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                            </a>
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>
              )}
            </div>

            <aside class="article-sidebar">
              <div class="article-sidebar-card article-author-box">
                <div class="av">{authorInitials}</div>
                <div class="nm">{authorName}</div>
                <div class="rl">Aurelis Editorial Team</div>
                <p>Expert reviews and curated buying guides from the people who select every product in our collection.</p>
              </div>
              <div class="article-sidebar-cta">
                <p>Discover the products our editors stand behind.</p>
                <a href="/products">
                  Shop The Collection
                  <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="13" height="13" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </a>
              </div>
            </aside>

          </div>
        </div>
      </article>
    </>
  )}

  <Newsletter />
</BaseLayout>
