# ─────────────────────────────────────────────────────────────
#  Shopify Storefront API — SERVER-SIDE secrets (copy to .env).
#  No PUBLIC_ prefix => kept on the server only, never shipped
#  to the browser. The storefront proxies all Shopify calls via
#  same-origin /api/* routes using the private token.
# ─────────────────────────────────────────────────────────────

# Your store's myshopify domain, e.g. your-shop.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com

# Storefront API private (delegate) access token — server only.
# Header used: Shopify-Storefront-Private-Token
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# Pin the API version. Do not use unversioned URLs.
SHOPIFY_API_VERSION=2026-04

# ─────────────────────────────────────────────────────────────
#  Customer Account API — login / account pages (OPTIONAL).
#  Leave blank to keep Sign In disabled (the header shows a
#  friendly "not available yet" page instead of breaking).
#
#  Setup (Shopify admin → Settings → Customer accounts →
#  "Customer Account API" / Headless or Hydrogen app):
#   1. Create a Customer Account API client (public, PKCE).
#   2. Copy the Client ID and the Shop ID below.
#   3. Register the callback URL: https://<your-host>/account/authorize
#      and the JavaScript origin: https://<your-host>
#   NOTE: Shopify rejects http/localhost for this API — run an
#   HTTPS tunnel (e.g. cloudflared / ngrok) in local dev.
# ─────────────────────────────────────────────────────────────

# Public OAuth client id of the Customer Account API app.
CUSTOMER_ACCOUNT_API_CLIENT_ID=

# Numeric shop id (shown on the Customer Account API settings page).
SHOPIFY_SHOP_ID=

# Customer Account API version (separate from the Storefront version).
CUSTOMER_ACCOUNT_API_VERSION=2025-01
